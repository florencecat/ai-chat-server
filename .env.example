# Server
PORT=8091

# GigaChat auth — задайте ЛИБО GIGACHAT_AUTH_KEY (готовая Base64-строка
# «Авторизационные данные» из личного кабинета), ЛИБО пару client id/secret.
GIGACHAT_AUTH_KEY=your-base64-authorization-key
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# GigaChat options
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_SKIP_TLS=true

# Request formatting
SYSTEM_PROMPT=Ты — полезный ассистент. Отвечай строго в формате JSON. Никакого текста вне JSON-объекта.
MAX_MESSAGE_LEN=4000

# Cache
CACHE_TTL=1h

# Quota (применяется к записям коллекции tokens в PocketBase)
QUOTA_PER_MINUTE=1
QUOTA_PER_DAY=15

# Storage (BoltDB — используется только для кэша)
DB_PATH=data/ai-server.db

# PocketBase
PB_URL=http://127.0.0.1:8090
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=your-superuser-password
